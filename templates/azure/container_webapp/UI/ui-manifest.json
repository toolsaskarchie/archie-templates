{
  "metadata": {
    "name": "azure-container-webapp",
    "title": "Container Web App",
    "description": "Deploy an Archie-branded congratulations page as a containerized web app on Azure App Service.",
    "category": "compute",
    "cloud": "azure",
    "version": "latest",
    "author": "InnovativeApps",
    "tags": [
      "azure",
      "app-service",
      "container",
      "docker",
      "webapp"
    ],
    "base_cost": "$0.00/month (Free Tier)",
    "complexity": "low",
    "deployment_time": "5-7 minutes",
    "marketplace_group": "WEBSITES",
    "action_name": "azure-container-webapp",
    "environment": "prod",
    "tier": "template",
    "use_cases": [
      "Production workloads",
      "Mission-critical applications",
      "Enterprise-grade infrastructure"
    ]
  },
  "configuration": {
    "type": "object",
    "required": [
      "appName",
      "resourceGroup"
    ],
    "properties": {
      "appName": {
        "type": "string",
        "title": "App Name",
        "default": "my-azure-app"
      },
      "resourceGroup": {
        "type": "string",
        "title": "Resource Group"
      },
      "location": {
        "type": "string",
        "title": "Azure Region",
        "default": "eastus"
      }
    },
    "smart_defaults": {}
  },
  "resources": [
    {
      "id": "azure-container-webapp:index-html",
      "type": "aws:s3:BucketObject",
      "name": "index-html",
      "description": "Archie-branded congratulations page (index.html)",
      "category": "Storage",
      "smart_defaults": {
        "key": "index.html",
        "content_type": "text/html",
        "tags": {
          "Name": "archie-index-html-{environment}",
          "ManagedBy": "Archie"
        }
      },
      "optional": false,
      "dependencies": [],
      "dependents": []
    },
    {
      "id": "azure-container-webapp:styles-css",
      "type": "aws:s3:BucketObject",
      "name": "styles-css",
      "description": "Styles with dark/light theme support (styles.css)",
      "category": "Storage",
      "smart_defaults": {
        "key": "styles.css",
        "content_type": "text/css",
        "tags": {
          "Name": "archie-styles-css-{environment}",
          "ManagedBy": "Archie"
        }
      },
      "optional": false,
      "dependencies": [],
      "dependents": []
    },
    {
      "id": "azure-container-webapp:{project_name}-rg",
      "type": "azure-native:resources:ResourceGroup",
      "name": "{project_name}-rg",
      "description": "azure-native:resources:ResourceGroup resource",
      "category": "Other",
      "smart_defaults": {
        "location": "{config_location}",
        "tags": {
          "ManagedBy": "Archie"
        }
      },
      "optional": false,
      "dependencies": [],
      "dependents": []
    },
    {
      "id": "azure-container-webapp:{project_name}-plan",
      "type": "azure-native:web:AppServicePlan",
      "name": "{project_name}-plan",
      "description": "azure-native:web:AppServicePlan resource",
      "category": "Other",
      "smart_defaults": {
        "name": "plan-{safe_project}-{random_suffix}",
        "resource_group_name": "{config_name}",
        "location": "{config_location}",
        "kind": "Linux",
        "reserved": true,
        "sku": {
          "name": "F1",
          "tier": "Free"
        },
        "tags": {
          "ManagedBy": "Archie"
        }
      },
      "optional": false,
      "dependencies": [],
      "dependents": []
    },
    {
      "id": "azure-container-webapp:{project_name}-app",
      "type": "azure-native:web:WebApp",
      "name": "{project_name}-app",
      "description": "azure-native:web:WebApp resource",
      "category": "Other",
      "smart_defaults": {
        "name": "{safe_project}-app-{random_suffix}",
        "resource_group_name": "{config_name}",
        "location": "{config_location}",
        "server_farm_id": "{config_id}",
        "https_only": true,
        "site_config": "{computed}",
        "tags": {
          "ManagedBy": "Archie"
        }
      },
      "optional": false,
      "dependencies": [],
      "dependents": []
    }
  ],
  "pillars": {
    "security": {
      "score": "fair",
      "description": "Implements security best practices for cloud infrastructure.",
      "best_practices": [
        "Basic security configurations",
        "Access control mechanisms"
      ]
    },
    "reliability": {
      "score": "fair",
      "description": "Ensures high availability and fault tolerance.",
      "best_practices": [
        "Automated recovery mechanisms",
        "Fault-tolerant architecture patterns"
      ]
    },
    "performance_efficiency": {
      "score": "good",
      "description": "Optimizes resource utilization and performance with scalable compute resources and efficient networking.",
      "best_practices": [
        "Elastic Load Balancing for traffic distribution"
      ]
    },
    "cost_optimization": {
      "score": "good",
      "description": "Balances cost efficiency with reliability through appropriate resource sizing and usage-based pricing.",
      "best_practices": [
        "Environment-specific parameter handling",
        "On-demand resource provisioning"
      ]
    },
    "operational_excellence": {
      "score": "excellent",
      "description": "Enables operational best practices with infrastructure as code, monitoring, and automated management.",
      "best_practices": [
        "Infrastructure as Code with Pulumi for automated deployments",
        "Comprehensive logging with CloudWatch",
