      },
      "optional": false,
      "dependencies": [],
      "dependents": []
    },
    {
      "id": "aws-vpc-nonprod:rt-private-{project}-{environment}-{region_short}",
      "type": "aws:ec2:RouteTable",
      "name": "rt-private-{project}-{environment}-{region_short}",
      "description": "Route table for private tier network traffic routing",
      "category": "Other",
      "smart_defaults": {
        "vpc_id": "{config_id}",
        "tags": {
          "Name": "{private_rt_name}",
          "Tier": "private"
        }
      },
      "optional": false,
      "dependencies": [],
      "dependents": []
    },
    {
      "id": "aws-vpc-nonprod:rt-public-{project}-{environment}-{region_short}",
      "type": "aws:ec2:RouteTable",
      "name": "rt-public-{project}-{environment}-{region_short}",
      "description": "Route table for public tier network traffic routing",
      "category": "Other",
      "smart_defaults": {
        "vpc_id": "{config_id}",
        "tags": {
          "Name": "{public_rt_name}",
          "Tier": "public"
        }
      },
      "optional": false,
      "dependencies": [],
      "dependents": []
    },
    {
      "id": "aws-vpc-nonprod:route-00000-{project}-{environment}-{region_short}-igw",
      "type": "aws:ec2:Route",
      "name": "route-00000-{project}-{environment}-{region_short}-igw",
      "description": "Route directing 0.0.0.0/0 traffic to Internet Gateway",
      "category": "Other",
      "smart_defaults": {
        "route_table_id": "{id}",
        "destination_cidr_block": "0.0.0.0/0",
        "gateway_id": "{config_id}"
      },
      "optional": false,
      "dependencies": [],
      "dependents": []
    },
    {
      "id": "aws-vpc-nonprod:route-00000-{project}-{environment}-{region_short}-nat",
      "type": "aws:ec2:Route",
      "name": "route-00000-{project}-{environment}-{region_short}-nat",
      "description": "Route directing 0.0.0.0/0 traffic to NAT Gateway",
      "category": "Other",
      "smart_defaults": {
        "route_table_id": "{id}",
        "destination_cidr_block": "0.0.0.0/0",
        "nat_gateway_id": "{config_id}"
      },
      "optional": false,
      "dependencies": [],
