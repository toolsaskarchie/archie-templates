{
  "metadata": {
    "name": "aws-rds-postgres-nonprod",
    "title": "PostgreSQL Database",
    "description": "Cost-optimized managed PostgreSQL deployment for development and staging.",
    "category": "database",
    "version": "latest",
    "author": "InnovativeApps",
    "cloud": "aws",
    "environment": "nonprod",
    "base_cost": "$20/month",
    "features": [
      "GP3 Storage with Auto-Scaling",
      "Secrets Manager Password Integration",
      "Automated Backups",
      "VPC Isolation",
      "Performance Insights"
    ],
    "tags": [
      "rds",
      "postgres",
      "database",
      "nonprod"
    ],
    "deployment_time": "10-15 minutes",
    "complexity": "medium",
    "pillars": [
      {
        "title": "Efficiency",
        "score": "excellent",
        "score_color": "#10b981",
        "description": "GP3 and burstable instances minimize costs."
      }
    ],
    "architecture": {
      "optional_features": [
        "Performance Insights (optional)"
      ],
      "summary": "RDS PostgreSQL Non-Production Template"
    },
    "action_name": "aws-rds-postgres-nonprod",
    "tier": "template",
    "use_cases": [
      "Development and testing environments",
      "Staging infrastructure",
      "Non-production workloads"
    ]
  },
  "configuration": {
    "type": "object",
    "required": [
      "dbName"
    ],
    "properties": {
      "resource_prefix": {
        "type": "string",
        "title": "Resource Prefix",
        "description": "Get resource name prefix",
        "group": "General Settings",
        "order": 1
      },
      "deletion_protection_enabled": {
        "type": "boolean",
        "title": "Deletion Protection Enabled",
        "description": "Deletion protection disabled for nonprod",
        "group": "General Settings",
        "order": 2
      },
      "vpc_header": {
        "type": "separator",
        "title": "VPC Configuration",
        "group": "Networking & Connectivity",
        "isEssential": true,
        "order": 10
      },
      "vpc_mode": {
        "type": "select",
        "title": "VPC Selection",
        "description": "Deploy into a new or existing VPC",
        "default": "new",
        "options": [
          {
            "label": "Create New VPC",
            "value": "new"
          },
          {
            "label": "Use Existing VPC",
            "value": "existing"
          }
        ],
        "group": "Networking & Connectivity",
        "isEssential": false,
        "order": 11
      },
      "vpc_id": {
        "type": "string",
        "title": "Existing VPC ID",
        "description": "ID of the existing VPC",
        "placeholder": "vpc-xxxxxxxx",
        "group": "Networking & Connectivity",
        "visibleIf": {
          "vpc_mode": "existing"
        },
        "isEssential": false,
        "order": 12
      },
      "subnet_id": {
        "type": "string",
        "title": "Subnet ID",
        "description": "Select existing Subnet",
        "placeholder": "subnet-xxxxxxxx",
        "group": "Networking & Connectivity",
        "visibleIf": {
          "vpc_mode": "existing"
        },
        "isEssential": false,
        "order": 13
      },
      "vpc_name": {
        "type": "string",
        "title": "VPC Name",
        "description": "Custom name for the new VPC",
        "placeholder": "Auto-generated",
        "group": "Networking & Connectivity",
        "visibleIf": {
          "vpc_mode": "new"
        },
        "isEssential": true,
        "order": 20
      },
      "instance_tenancy": {
        "type": "select",
        "title": "VPC Tenancy",
        "description": "The allowed tenancy of instances launched into the VPC",
        "default": "default",
        "options": [
          {
            "label": "Default",
            "value": "default"
          },
          {
            "label": "Dedicated",
            "value": "dedicated"
          }
        ],
        "group": "Networking & Connectivity",
        "visibleIf": {
          "vpc_mode": "new"
        },
        "order": 22
      },
      "cidr_block": {
        "type": "string",
        "title": "VPC CIDR Block",
        "description": "IPv4 CIDR block for the new VPC",
        "default": "",
        "placeholder": "Auto-Assign",
        "group": "Networking & Connectivity",
        "visibleIf": {
          "vpc_mode": "new"
        },
        "isEssential": true,
        "order": 23
      },
      "dns_header": {
        "type": "separator",
        "title": "DNS Configuration",
        "group": "Networking & Connectivity",
        "visibleIf": {
          "vpc_mode": "new"
        },
        "isEssential": true,
        "order": 69
      },
      "enable_dns_support": {
        "type": "boolean",
        "title": "Enable DNS Support",
        "description": "Allow DNS resolution",
        "default": true,
        "group": "Networking & Connectivity",
        "visibleIf": {
          "vpc_mode": "new"
        },
        "isEssential": true,
        "order": 70
      },
      "enable_dns_hostnames": {
        "type": "boolean",
        "title": "Enable DNS Hostnames",
        "description": "Assign public hostnames",
        "default": true,
        "group": "Networking & Connectivity",
        "visibleIf": {
          "vpc_mode": "new"
        },
        "isEssential": true,
        "order": 71
      },
      "subnet_header": {
        "type": "separator",
        "title": "Subnet Configuration",
        "group": "Networking & Connectivity",
        "visibleIf": {
          "vpc_mode": "new"
        },
        "order": 29
      },
      "public_subnet_1_cidr": {
        "type": "string",
        "title": "Public Subnet 1 CIDR",
        "placeholder": "e.g. 10.0.1.0/24",
        "group": "Networking & Connectivity",
        "visibleIf": {
          "vpc_mode": "new"
        },
        "order": 30
      },
      "az_1": {
        "type": "string",
        "title": "Availability Zone 1",
        "placeholder": "e.g. us-east-1a",
        "group": "Networking & Connectivity",
        "visibleIf": {
          "vpc_mode": "new"
        },
        "order": 31
      },
      "private_subnet_1_cidr": {
        "type": "string",
        "title": "Private Subnet 1 CIDR",
        "placeholder": "e.g. 10.0.11.0/24",
        "group": "Networking & Connectivity",
        "visibleIf": {
          "vpc_mode": "new"
        },
        "order": 32
      },
      "zone_2_separator": {
        "type": "separator",
        "title": "Secondary Zone Configuration",
        "group": "Networking & Connectivity",
        "visibleIf": {
          "vpc_mode": "new"
        },
        "order": 34
      },
      "public_subnet_2_cidr": {
        "type": "string",
        "title": "Public Subnet 2 CIDR",
        "placeholder": "e.g. 10.0.2.0/24",
        "group": "Networking & Connectivity",
        "visibleIf": {
          "vpc_mode": "new"
        },
        "order": 35
      },
      "az_2": {
        "type": "string",
        "title": "Availability Zone 2",
        "placeholder": "e.g. us-east-1b",
        "group": "Networking & Connectivity",
        "visibleIf": {
          "vpc_mode": "new"
        },
        "order": 36
      },
      "private_subnet_2_cidr": {
        "type": "string",
        "title": "Private Subnet 2 CIDR",
        "placeholder": "e.g. 10.0.12.0/24",
        "group": "Networking & Connectivity",
        "visibleIf": {
          "vpc_mode": "new"
        },
        "order": 37
      },
      "nat_header": {
        "type": "separator",
        "title": "NAT Gateway Configuration",
        "group": "Networking & Connectivity",
        "visibleIf": {
          "vpc_mode": "new"
        },
        "isEssential": true,
        "order": 59
      },
      "enable_nat_gateway": {
        "type": "boolean",
        "title": "Provision NAT Gateway",
        "description": "Provide internet access to private subnets",
        "default": true,
        "group": "Networking & Connectivity",
        "visibleIf": {
          "vpc_mode": "new"
        },
        "isEssential": true,
        "order": 60
      },
      "nat_gateway_count": {
        "type": "number",
        "title": "NAT Gateway Count",
        "description": "1 for cost-optimization, 2-3 for higher availability",
        "default": 1,
        "options": [
          {
            "label": "Single (Cost Optimized)",
            "value": 1
          },
          {
            "label": "Double (High Availability)",
            "value": 2
          }
        ],
        "group": "Networking & Connectivity",
        "visibleIf": {
          "enable_nat_gateway": true
        },
        "order": 61
      },
      "db_header": {
        "type": "separator",
        "title": "Database Configuration",
        "group": "Database Settings",
        "isEssential": true,
        "order": 80
      },
      "dbName": {
        "type": "string",
        "title": "Database Name",
        "description": "Primary database name",
        "default": "mydb",
        "group": "Database Settings",
        "isEssential": true,
        "order": 81
      },
      "dbUsername": {
        "type": "string",
        "title": "Master Username",
        "description": "Database administrator username",
        "default": "postgres",
        "group": "Database Settings",
        "isEssential": true,
        "order": 82
      },
      "engineVersion": {
        "type": "string",
        "title": "Engine Version",
        "description": "Version of postgres",
        "default": "15",
        "group": "Database Settings",
        "order": 83
      },
      "instanceClass": {
        "type": "string",
        "title": "Instance Class",
        "description": "Compute and memory capacity",
        "default": "db.t3.micro",
        "enum": [
          "db.t3.micro",
          "db.t3.small",
          "db.t3.medium",
          "db.t3.large",
          "db.m5.large"
        ],
        "group": "Database Settings",
        "isEssential": true,
        "order": 84
      },
      "allocatedStorage": {
        "type": "number",
        "title": "Allocated Storage (GB)",
        "description": "Initial storage capacity",
        "default": 20,
        "group": "Database Settings",
        "order": 85
      },
      "maxAllocatedStorage": {
        "type": "number",
        "title": "Max Storage (GB)",
        "description": "Auto-scaling storage limit",
        "default": 100,
        "group": "Database Settings",
        "order": 86
      },
      "backupRetentionDays": {
        "type": "number",
        "title": "Backup Retention (Days)",
        "description": "Number of days to keep backups",
        "default": 3,
        "group": "Database Settings",
        "order": 87
      },
      "security_header": {
        "type": "separator",
        "title": "Security Group Configuration",
        "group": "Security & Connectivity",
        "isEssential": true,
        "order": 155
      },
      "ssh_mode": {
        "type": "select",
        "title": "Access Mode",
        "description": "Choose between secure SSM access or emergency SSH/RDP",
        "default": "ssm-only",
        "options": [
          {
            "label": "Standard (SSM Only)",
            "value": "ssm-only"
          },
          {
            "label": "Advanced (Enable SSH/RDP)",
            "value": "enabled"
          }
        ],
        "group": "Security & Connectivity",
        "isEssential": false,
        "order": 160,
        "help_text": "Standard Security Policy\nSSH and RDP ports remain closed. Secure management via AWS Systems Manager (SSM) is enabled by default."
      },
      "ssh_access_ip": {
        "type": "string",
        "title": "Admin Access IP (SSH/RDP)",
        "description": "IP address or CIDR block (required for advanced mode)",
        "placeholder": "e.g. 203.0.113.25/32",
        "group": "Security & Connectivity",
        "visibleIf": {
          "ssh_mode": "enabled"
        },
        "isEssential": true,
        "order": 161
      },
      "endpoint_header": {
        "type": "separator",
        "title": "Endpoint Configuration",
        "group": "Security & Connectivity",
        "isEssential": true,
        "order": 170
      },
      "enable_ssm_endpoints": {
        "type": "boolean",
        "title": "Enable SSM Endpoints",
        "description": "Interface Endpoints for secure management",
        "default": true,
        "help_text": "Required for secure instance access without SSH/IGW.",
        "group": "Security & Connectivity",
        "isEssential": true,
        "order": 171
      },
      "enable_s3_endpoint": {
        "type": "boolean",
        "title": "Enable S3 Endpoint",
        "description": "Private gateway access to S3",
        "default": true,
        "group": "Security & Connectivity",
        "isEssential": true,
        "order": 172
      },
      "enable_dynamodb_endpoint": {
        "type": "boolean",
        "title": "Enable DynamoDB Endpoint",
        "description": "Private gateway access to DynamoDB",
        "default": true,
        "group": "Security & Connectivity",
        "isEssential": true,
        "order": 173
      },
      "port_header": {
        "type": "separator",
        "title": "Custom Port Overrides",
        "group": "Security & Connectivity",
        "isEssential": true,
        "order": 180
      },
      "web_port": {
        "type": "number",
        "title": "Web Traffic Port",
        "description": "Standard port for web traffic (HTTP)",
        "default": 80,
        "group": "Security & Connectivity",
        "isEssential": true,
        "order": 181
      },
      "app_port": {
        "type": "number",
        "title": "Application Port",
        "description": "Port for internal application services",
        "default": 8080,
        "group": "Security & Connectivity",
        "isEssential": true,
        "order": 182
      },
      "db_port": {
        "type": "number",
        "title": "Database Port",
        "description": "Port for database connections",
        "default": 5432,
        "group": "Security & Connectivity",
        "isEssential": true,
        "order": 183
      },
      "flow_logs_header": {
        "type": "separator",
        "title": "Flow Logs Configuration",
        "group": "Observability",
        "isEssential": true,
        "order": 200
      },
      "enable_flow_logs": {
        "type": "boolean",
        "title": "Enable Flow Logs",
        "description": "Capture IP traffic information",
        "default": true,
        "group": "Observability",
        "isEssential": true,
        "order": 201
      },
      "log_destination_type": {
        "type": "select",
        "title": "Flow Log Destination",
        "description": "Where to store flow logs",
        "default": "cloud-watch-logs",
        "options": [
          {
            "label": "CloudWatch Logs",
            "value": "cloud-watch-logs"
          },
          {
            "label": "S3 Bucket",
            "value": "s3"
          }
        ],
        "group": "Observability",
        "visibleIf": {
          "enable_flow_logs": true
        },
        "order": 202
      },
      "flow_log_retention": {
        "type": "number",
        "title": "Log Retention (Days)",
        "description": "How long to keep flow logs",
        "default": 7,
        "group": "Observability",
        "visibleIf": {
          "enable_flow_logs": true
        },
        "order": 203
      }
    },
    "smart_defaults": {}
  },
  "resources": [
    {
      "id": "aws-rds-postgres-nonprod:{namer_resource}",
      "type": "aws:rds:SubnetGroup",
      "name": "{namer_resource}",
      "description": "SubnetGroup resource",
      "category": "Other",
      "smart_defaults": {
        "subnet_ids": "{config_subnet_ids}",
        "description": "Subnet group for {db_identifier}",
        "tags": {
          "Name": "{sng_name}"
        }
      },
      "optional": false,
      "dependencies": [],
      "dependents": []
    },
    {
      "id": "aws-rds-postgres-nonprod:{namer_rds}",
      "type": "aws:rds:Instance",
      "name": "{namer_rds}",
      "description": "Instance resource",
      "category": "Other",
      "smart_defaults": {
        "engine": "postgres",
        "engine_version": "{config_engine_version}",
        "instance_class": "{config_db_instance_class}",
        "allocated_storage": "{config_allocated_storage}",
        "max_allocated_storage": "{config_max_allocated_storage}",
        "username": "{config_db_username}",
        "password": "{db_password}",
        "db_subnet_group_name": "{config_name}",
        "vpc_security_group_ids": [
          "{sg_id}"
        ],
        "db_name": "{config_db_name}",
        "storage_type": "gp3",
        "storage_encrypted": "{config_storage_encrypted}",
        "publicly_accessible": "{config_publicly_accessible}",
        "multi_az": "{config_multi_az}",
        "backup_retention_period": "{config_backup_retention_days}",
        "skip_final_snapshot": "{config_skip_final_snapshot}",
        "deletion_protection": "{config_deletion_protection_enabled}",
        "performance_insights_enabled": "{config_enable_performance_insights}",
        "tags": {
          "Name": "{db_identifier}"
        }
      },
      "optional": false,
      "dependencies": [],
      "dependents": []
    },
    {
      "id": "aws-rds-postgres-nonprod:{project_name}-password",
      "type": "aws:secretsmanager:Secret",
      "name": "{project_name}-password",
      "description": "Secret resource - {project_name}-password",
      "category": "Security",
      "smart_defaults": {},
      "optional": false,
      "dependencies": [],
      "dependents": []
    },
    {
      "id": "aws-rds-postgres-nonprod:{project_name}-password-version",
      "type": "aws:secretsmanager:SecretVersion",
      "name": "{project_name}-password-version",
      "description": "SecretVersion resource - {project_name}-password-version",
      "category": "Security",
      "smart_defaults": {},
      "optional": false,
      "dependencies": [],
      "dependents": []
    },
    {
      "id": "aws-vpc-nonprod:vpc-{project}-{environment}-{region_short}-{network_num}",
      "type": "aws:ec2:Vpc",
      "name": "vpc-{project}-{environment}-{region_short}-{network_num}",
      "description": "Virtual Private Cloud with CIDR {config_custom_cidr_block}, DNS support enabled",
      "category": "Other",
      "smart_defaults": {
        "cidr_block": "{config_custom_cidr_block}",
        "enable_dns_support": "{config_enable_dns_support}",
        "enable_dns_hostnames": "{config_enable_dns_hostnames}",
        "instance_tenancy": "{config_instance_tenancy}",
        "tags": {
          "Name": "{vpc_name}"
        }
      },
      "optional": false,
      "dependencies": [],
      "dependents": []
    },
    {
      "id": "aws-vpc-nonprod:igw-main-{project}-{environment}-{region_short}",
      "type": "aws:ec2:InternetGateway",
      "name": "igw-main-{project}-{environment}-{region_short}",
      "description": "Internet Gateway providing public internet connectivity for the VPC",
      "category": "Other",
      "smart_defaults": {
        "vpc_id": "{config_id}",
        "tags": {
          "Name": "{igw_name}"
        }
      },
      "optional": false,
      "dependencies": [],
      "dependents": []
    },
    {
      "id": "aws-vpc-nonprod:isolatedsub-{project}-{environment}-{region_short}-{az_short}-{subnet_num}",
      "type": "aws:ec2:Subnet",
      "name": "isolatedsub-{project}-{environment}-{region_short}-{az_short}-{subnet_num}",
      "description": "Private subnet for isolated tier workloads (CIDR: {isolated_cidr})",
      "category": "Other",
      "smart_defaults": {
        "vpc_id": "{config_id}",
        "cidr_block": "{isolated_cidr}",
        "availability_zone": "{config_region}a",
        "map_public_ip_on_launch": false,
        "tags": {
          "Name": "{isolated_subnet_name}",
          "Tier": "isolated"
        }
      },
      "optional": false,
      "dependencies": [],
      "dependents": []
    },
    {
      "id": "aws-vpc-nonprod:privsub-{project}-{environment}-{region_short}-{az_short}-{subnet_num}",
      "type": "aws:ec2:Subnet",
      "name": "privsub-{project}-{environment}-{region_short}-{az_short}-{subnet_num}",
      "description": "Private subnet for private tier workloads (CIDR: {private_cidr})",
      "category": "Other",
      "smart_defaults": {
        "vpc_id": "{config_id}",
        "cidr_block": "{private_cidr}",
        "availability_zone": "{config_region}a",
        "map_public_ip_on_launch": false,
        "tags": {
          "Name": "{private_subnet_name}",
          "Tier": "private"
        }
      },
      "optional": false,
      "dependencies": [],
      "dependents": []
    },
    {
      "id": "aws-vpc-nonprod:pubsub-{project}-{environment}-{region_short}-{az_short}-{subnet_num}",
      "type": "aws:ec2:Subnet",
      "name": "pubsub-{project}-{environment}-{region_short}-{az_short}-{subnet_num}",
      "description": "Public subnet for public tier workloads (CIDR: {public_cidr})",
      "category": "Other",
      "smart_defaults": {
        "vpc_id": "{config_id}",
        "cidr_block": "{public_cidr}",
        "availability_zone": "{config_region}a",
        "map_public_ip_on_launch": true,
        "tags": {
          "Name": "{public_subnet_name}",
          "Tier": "public"
        }
      },
      "optional": false,
      "dependencies": [],
      "dependents": []
    },
    {
