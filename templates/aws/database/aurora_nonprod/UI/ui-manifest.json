        }
      },
      "optional": false,
      "dependencies": [],
      "dependents": []
    },
    {
      "id": "aws-vpc-nonprod:vpce-rds-{project}-{environment}-{region_short}-if",
      "type": "aws:ec2:VpcEndpoint",
      "name": "vpce-rds-{project}-{environment}-{region_short}-if",
      "description": "RDS Interface VPC Endpoint for private RDS service access",
      "category": "Other",
      "smart_defaults": {
        "vpc_id": "{config_id}",
        "service_name": "com.amazonaws.{config_region}.rds",
        "vpc_endpoint_type": "Interface",
        "subnet_ids": [
          "{id}"
