{
  "metadata": {
    "name": "aws-aurora-nonprod",
    "title": "Aurora Database Cluster",
    "description": "Cost-optimized managed Aurora PostgreSQL or MySQL-compatible database cluster designed for development and staging.",
    "category": "database",
    "version": "latest",
    "author": "InnovativeApps",
    "cloud": "aws",
    "environment": "nonprod",
    "base_cost": "$45/month",
    "features": [
      "Serverless v2 Scaling Support",
      "Managed Aurora Cluster with automated failover",
      "Optional Read Replicas for load distribution",
      "Secure Identity: Automated password rotation via Secrets Manager",
      "Automated Backups with 3-day retention for non-prod safety"
    ],
    "tags": [
      "aws",
      "database",
      "aurora",
      "postgresql",
      "mysql",
      "nonprod",
      "cost-optimized"
    ],
    "deployment_time": "15-20 minutes",
    "complexity": "medium",
    "architecture": {
      "summary": "Aurora Non-Production Template"
    },
    "action_name": "aws-aurora-nonprod",
    "tier": "template",
    "use_cases": [
      "Development and testing environments",
      "Staging infrastructure",
      "Non-production workloads"
    ]
  },
  "configuration": {
    "type": "object",
    "required": [
      "project_name",
      "db_name",
      "region"
    ],
    "properties": {
      "use_custom_cidr": {
        "type": "boolean",
        "default": false,
        "title": "Use Custom CIDR",
        "description": "Enable to specify a custom IPv4 CIDR block for the VPC",
        "order": 10,
        "group": "Network Configuration",
        "cost_impact": "$0/month"
      },
      "custom_cidr_block": {
        "type": "string",
        "default": "10.0.0.0/16",
        "title": "Custom CIDR Block",
        "description": "Specify custom IPv4 CIDR block (e.g., 10.0.0.0/16, 172.16.0.0/16, 192.168.0.0/16)",
        "order": 11,
        "group": "Network Configuration",
        "conditional": {
          "field": "use_custom_cidr"
        }
      },
      "enable_dns_support": {
        "type": "boolean",
        "default": true,
        "title": "Enable DNS Support",
        "description": "Enable DNS resolution in the VPC",
        "order": 12,
        "group": "Network Configuration"
      },
      "enable_dns_hostnames": {
        "type": "boolean",
        "default": true,
        "title": "Enable DNS Hostnames",
        "description": "Enable DNS hostnames for instances",
        "order": 13,
        "group": "Network Configuration"
      },
      "enable_ssh_access": {
        "type": "boolean",
        "default": true,
        "title": "Enable SSH Access",
        "description": "Enable SSH/RDP access to instances",
        "order": 14,
        "group": "Network Configuration",
        "cost_impact": "+$0/month"
      },
      "ssh_access_ip": {
        "type": "string",
        "title": "Admin Access IP (SSH/RDP)",
        "description": "IP address or CIDR block (required for advanced mode)",
        "placeholder": "e.g. 203.0.113.25/32",
        "group": "Security & Connectivity",
        "visibleIf": {
          "ssh_mode": "enabled"
        },
        "isEssential": true,
        "order": 161
      },
      "enable_isolated_tier": {
        "type": "boolean",
        "default": false,
        "title": "Enable Isolated Subnet Tier",
        "description": "Creates isolated subnet with no internet access for databases",
        "order": 101,
        "group": "High Availability & Cost",
        "cost_impact": "+$0/month (no additional cost)"
      },
      "enable_flow_logs": {
        "type": "boolean",
        "title": "Enable Flow Logs",
        "description": "Capture IP traffic information",
        "default": true,
        "group": "Observability",
        "isEssential": true,
        "order": 201
      },
      "flow_log_retention": {
        "type": "number",
        "title": "Log Retention (Days)",
        "description": "How long to keep flow logs",
        "default": 7,
        "group": "Observability",
        "visibleIf": {
          "enable_flow_logs": true
        },
        "order": 203
      },
      "enable_rds_endpoint": {
        "type": "boolean",
        "default": false,
        "title": "Enable RDS VPC Endpoint",
        "description": "Private interface endpoint for RDS API calls",
        "order": 102,
        "group": "High Availability & Cost",
        "cost_impact": "+$14/month"
      },
      "enable_ssm_endpoints": {
        "type": "boolean",
        "title": "Enable SSM Endpoints",
        "description": "Interface Endpoints for secure management",
        "default": true,
        "help_text": "Required for secure instance access without SSH/IGW.",
        "group": "Security & Connectivity",
        "isEssential": true,
        "order": 171
      },
      "db_header": {
        "type": "separator",
        "title": "Database Configuration",
        "group": "Database Settings",
        "isEssential": true,
        "order": 80
      },
      "dbName": {
        "type": "string",
        "title": "Database Name",
        "description": "Primary database name",
        "default": "mydb",
        "group": "Database Settings",
        "isEssential": true,
        "order": 81
      },
      "dbUsername": {
        "type": "string",
        "title": "Master Username",
        "description": "Database administrator username",
        "default": "admin",
        "group": "Database Settings",
        "isEssential": true,
        "order": 82
      },
      "engineVersion": {
        "type": "string",
        "title": "Engine Version",
        "description": "Version of aurora-postgresql",
        "default": "8.0",
        "group": "Database Settings",
        "order": 83
      },
      "instanceClass": {
        "type": "string",
        "title": "Instance Class",
        "description": "Compute and memory capacity",
        "default": "db.t3.micro",
        "enum": [
          "db.t3.micro",
          "db.t3.small",
          "db.t3.medium",
          "db.t3.large",
          "db.m5.large"
        ],
        "group": "Database Settings",
        "isEssential": true,
        "order": 84
      },
      "allocatedStorage": {
        "type": "number",
        "title": "Allocated Storage (GB)",
        "description": "Initial storage capacity",
        "default": 20,
        "group": "Database Settings",
        "order": 85
      },
      "maxAllocatedStorage": {
        "type": "number",
        "title": "Max Storage (GB)",
        "description": "Auto-scaling storage limit",
        "default": 100,
        "group": "Database Settings",
        "order": 86
      },
      "backupRetentionDays": {
        "type": "number",
        "title": "Backup Retention (Days)",
        "description": "Number of days to keep backups",
        "default": 3,
        "group": "Database Settings",
        "order": 87
      },
      "security_header": {
        "type": "separator",
        "title": "Security Group Configuration",
        "group": "Security & Connectivity",
        "isEssential": true,
        "order": 155
      },
      "ssh_mode": {
        "type": "select",
        "title": "Access Mode",
        "description": "Choose between secure SSM access or emergency SSH/RDP",
        "default": "ssm-only",
        "options": [
          {
            "label": "Standard (SSM Only)",
            "value": "ssm-only"
          },
          {
            "label": "Advanced (Enable SSH/RDP)",
            "value": "enabled"
          }
        ],
        "group": "Security & Connectivity",
        "isEssential": false,
        "order": 160,
        "help_text": "Standard Security Policy\nSSH and RDP ports remain closed. Secure management via AWS Systems Manager (SSM) is enabled by default."
      },
      "endpoint_header": {
        "type": "separator",
        "title": "Endpoint Configuration",
        "group": "Security & Connectivity",
        "isEssential": true,
        "order": 170
      },
      "enable_s3_endpoint": {
        "type": "boolean",
        "title": "Enable S3 Endpoint",
        "description": "Private gateway access to S3",
        "default": true,
        "group": "Security & Connectivity",
        "isEssential": true,
        "order": 172
      },
      "enable_dynamodb_endpoint": {
        "type": "boolean",
        "title": "Enable DynamoDB Endpoint",
        "description": "Private gateway access to DynamoDB",
        "default": true,
        "group": "Security & Connectivity",
        "isEssential": true,
        "order": 173
      },
      "port_header": {
        "type": "separator",
        "title": "Custom Port Overrides",
        "group": "Security & Connectivity",
        "isEssential": true,
        "order": 180
      },
      "web_port": {
        "type": "number",
        "title": "Web Traffic Port",
        "description": "Standard port for web traffic (HTTP)",
        "default": 80,
        "group": "Security & Connectivity",
        "isEssential": true,
        "order": 181
      },
      "app_port": {
        "type": "number",
        "title": "Application Port",
        "description": "Port for internal application services",
        "default": 8080,
        "group": "Security & Connectivity",
        "isEssential": true,
        "order": 182
      },
      "db_port": {
        "type": "number",
        "title": "Database Port",
        "description": "Port for database connections",
        "default": 5432,
        "group": "Security & Connectivity",
        "isEssential": true,
        "order": 183
      },
      "flow_logs_header": {
        "type": "separator",
        "title": "Flow Logs Configuration",
        "group": "Observability",
        "isEssential": true,
        "order": 200
      },
      "log_destination_type": {
        "type": "select",
        "title": "Flow Log Destination",
        "description": "Where to store flow logs",
        "default": "cloud-watch-logs",
        "options": [
          {
            "label": "CloudWatch Logs",
            "value": "cloud-watch-logs"
          },
          {
            "label": "S3 Bucket",
            "value": "s3"
          }
        ],
        "group": "Observability",
        "visibleIf": {
          "enable_flow_logs": true
        },
        "order": 202
      }
    },
    "smart_defaults": {}
  },
  "resources": [
    {
      "id": "aws-aurora-nonprod:{namer_rds}",
      "type": "aws:rds:Cluster",
      "name": "{namer_rds}",
      "description": "Cluster resource",
      "category": "Other",
      "smart_defaults": {
        "engine": "{config_engine}",
        "engine_version": "{config_engine_version}",
        "cluster_identifier": "{namer_rds}",
        "master_username": "{config_db_username}",
        "master_password": "{db_password}",
        "database_name": "{config_db_name}",
        "port": "{config_port}",
        "db_subnet_group_name": "{config_name}",
        "vpc_security_group_ids": [
          "{sg_id}"
        ],
        "backup_retention_period": "{config_backup_retention_days}",
        "storage_encrypted": "{config_storage_encrypted}",
        "availability_zones": "{availability_zones}",
        "deletion_protection": "{config_deletion_protection_enabled}",
        "skip_final_snapshot": "{config_skip_final_snapshot}",
        "tags": {
          "Name": "{db_identifier}"
        }
      },
      "optional": false,
      "dependencies": [],
      "dependents": []
    },
    {
      "id": "aws-aurora-nonprod:{namer_resource}",
      "type": "aws:rds:SubnetGroup",
      "name": "{namer_resource}",
      "description": "SubnetGroup resource",
      "category": "Other",
      "smart_defaults": {
        "subnet_ids": "{config_subnet_ids}",
        "description": "Subnet group for {db_identifier}",
        "tags": {
          "Name": "{sng_name}"
        }
      },
      "optional": false,
      "dependencies": [],
      "dependents": []
    },
    {
      "id": "aws-aurora-nonprod:{db_identifier}-instance-",
      "type": "aws:rds:ClusterInstance",
      "name": "{db_identifier}-instance-",
      "description": "ClusterInstance resource",
      "category": "Other",
      "smart_defaults": {
        "identifier": "{db_identifier}-instance-",
        "cluster_identifier": "{config_id}",
        "instance_class": "{config_instance_class}",
        "engine": "{config_engine}",
        "engine_version": "{config_engine_version}",
        "publicly_accessible": "{config_publicly_accessible}",
        "performance_insights_enabled": "{config_enable_performance_insights}",
        "tags": {
          "Name": "{instance_identifier}"
        }
      },
      "optional": false,
      "dependencies": [],
      "dependents": []
    },
    {
      "id": "aws-aurora-nonprod:{project_name}-password",
      "type": "aws:secretsmanager:Secret",
      "name": "{project_name}-password",
      "description": "Secret resource - {project_name}-password",
      "category": "Security",
      "smart_defaults": {},
      "optional": false,
      "dependencies": [],
      "dependents": []
    },
    {
      "id": "aws-aurora-nonprod:{project_name}-password-version",
      "type": "aws:secretsmanager:SecretVersion",
      "name": "{project_name}-password-version",
      "description": "SecretVersion resource - {project_name}-password-version",
      "category": "Security",
      "smart_defaults": {},
      "optional": false,
      "dependencies": [],
      "dependents": []
    },
    {
      "id": "aws-vpc-nonprod:vpc-{project}-{environment}-{region_short}-{network_num}",
      "type": "aws:ec2:Vpc",
      "name": "vpc-{project}-{environment}-{region_short}-{network_num}",
      "description": "Virtual Private Cloud with CIDR {config_custom_cidr_block}, DNS support enabled",
      "category": "Other",
      "smart_defaults": {
        "cidr_block": "{config_custom_cidr_block}",
        "enable_dns_support": "{config_enable_dns_support}",
        "enable_dns_hostnames": "{config_enable_dns_hostnames}",
        "instance_tenancy": "{config_instance_tenancy}",
        "tags": {
          "Name": "{vpc_name}"
        }
      },
      "optional": false,
      "dependencies": [],
      "dependents": []
    },
    {
      "id": "aws-vpc-nonprod:igw-main-{project}-{environment}-{region_short}",
      "type": "aws:ec2:InternetGateway",
      "name": "igw-main-{project}-{environment}-{region_short}",
      "description": "Internet Gateway providing public internet connectivity for the VPC",
      "category": "Other",
      "smart_defaults": {
        "vpc_id": "{config_id}",
        "tags": {
          "Name": "{igw_name}"
        }
      },
      "optional": false,
      "dependencies": [],
      "dependents": []
    },
    {
      "id": "aws-vpc-nonprod:isolatedsub-{project}-{environment}-{region_short}-{az_short}-{subnet_num}",
