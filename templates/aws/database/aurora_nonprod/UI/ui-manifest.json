      "description": "Route table for private tier network traffic routing",
      "category": "Other",
      "smart_defaults": {
        "vpc_id": "{config_id}",
        "tags": {
          "Name": "{private_rt_name}",
          "Tier": "private"
        }
      },
      "optional": false,
      "dependencies": [],
      "dependents": []
    },
    {
