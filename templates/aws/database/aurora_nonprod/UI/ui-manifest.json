      "category": "Other",
      "smart_defaults": {
        "vpc_id": "{config_id}",
        "tags": {
          "Name": "{public_rt_name}",
          "Tier": "public"
        }
      },
      "optional": false,
      "dependencies": [],
      "dependents": []
    },
    {
