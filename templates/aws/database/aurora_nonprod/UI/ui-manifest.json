      "type": "aws:ec2:VpcEndpoint",
      "name": "vpce-dynamodb-{project}-{environment}-{region_short}-gw",
      "description": "DYNAMODB Gateway VPC Endpoint for private DYNAMODB service access",
      "category": "Other",
      "smart_defaults": {
        "vpc_id": "{config_id}",
        "service_name": "com.amazonaws.{config_region}.dynamodb",
