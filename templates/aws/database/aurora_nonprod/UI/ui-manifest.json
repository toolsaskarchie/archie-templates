      "description": "Private subnet for private tier workloads (CIDR: {private_cidr})",
      "category": "Other",
      "smart_defaults": {
        "vpc_id": "{config_id}",
        "cidr_block": "{private_cidr}",
        "availability_zone": "{config_region}a",
        "map_public_ip_on_launch": false,
