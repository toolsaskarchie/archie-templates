{
  "metadata": {
    "name": "aws-rds-postgres",
    "title": "Enterprise PostgreSQL Database",
    "description": "Enterprise-ready PostgreSQL deployment featuring high-availability Multi-AZ architecture.",
    "category": "database",
    "version": "latest",
    "author": "InnovativeApps",
    "cloud": "aws",
    "environment": "prod",
    "base_cost": "$45/month",
    "features": [
      "High-Availability Multi-AZ Deployment",
      "Auto-Scaling gp3 Storage with Encryption at Rest",
      "Secure Password Management via AWS Secrets Manager",
      "Full VPC Isolation with Managed Security Groups",
      "Pre-configured CloudWatch Logs & Monitoring"
    ],
    "tags": [
      "database",
      "postgresql",
      "rds",
      "production",
      "high-availability"
    ],
    "complexity": "advanced",
    "deployment_time": "15-20 minutes",
    "action_name": "aws-rds-postgres",
    "tier": "template",
    "use_cases": [
      "Production workloads",
      "Mission-critical applications",
      "Enterprise-grade infrastructure"
    ]
  },
  "configuration": {
    "type": "object",
    "required": [
      "dbName",
      "dbUsername",
      "region",
      "project_name"
    ],
    "properties": {
      "cidr_block": {
        "type": "string",
        "default": "random",
        "title": "VPC CIDR Block",
        "description": "IPv4 CIDR block for the VPC (use 'random' for auto-generated)",
        "order": 10,
        "group": "Network Configuration"
      },
      "enable_dns_support": {
        "type": "boolean",
        "default": true,
        "title": "Enable DNS Support",
        "description": "Enable DNS resolution in the VPC",
        "order": 11,
        "group": "Network Configuration"
      },
      "enable_dns_hostnames": {
        "type": "boolean",
        "default": true,
        "title": "Enable DNS Hostnames",
        "description": "Enable DNS hostnames for instances",
        "order": 12,
        "group": "Network Configuration"
      },
      "az_1": {
        "type": "string",
        "default": "",
        "title": "Availability Zone 1",
        "description": "First availability zone (auto-selected if empty)",
        "order": 20,
        "group": "Availability Zones"
      },
      "az_2": {
        "type": "string",
        "default": "",
        "title": "Availability Zone 2",
        "description": "Second availability zone (auto-selected if empty)",
        "order": 21,
        "group": "Availability Zones"
      },
      "az_3": {
        "type": "string",
        "default": "",
        "title": "Availability Zone 3",
        "description": "Third availability zone (auto-selected if empty)",
        "order": 22,
        "group": "Availability Zones"
      },
      "enable_nat_gateway": {
        "type": "boolean",
        "default": true,
        "title": "Enable NAT Gateway",
        "description": "Creates NAT Gateway(s) for private subnet internet access",
        "order": 100,
        "group": "High Availability & Cost",
        "cost_impact": "+$96/month"
      },
      "nat_gateway_count": {
        "type": "integer",
        "default": 3,
        "title": "NAT Gateway Count",
        "description": "Number of NAT Gateways (1 or 3 for HA)",
        "order": 101,
        "group": "High Availability & Cost",
        "cost_impact": "+$32-96/month"
      },
      "enable_flow_logs": {
        "type": "boolean",
        "default": true,
        "title": "Enable VPC Flow Logs",
        "description": "Capture network traffic logs to S3 for security monitoring",
        "order": 110,
        "group": "High Availability & Cost",
        "cost_impact": "+$3/month"
      },
      "flow_log_retention": {
        "type": "integer",
        "default": 30,
        "title": "Flow Logs Retention (days)",
        "description": "How long to retain flow logs in S3 before auto-deletion",
        "order": 111,
        "group": "High Availability & Cost"
      },
      "enable_nacls": {
        "type": "boolean",
        "default": true,
        "title": "Enable Network ACLs",
        "description": "Create Network ACLs for subnet-level security",
        "order": 120,
        "group": "Security Settings",
        "cost_impact": "$0/month"
      },
      "enable_rds_endpoint": {
        "type": "boolean",
        "default": false,
        "title": "Enable RDS VPC Endpoint",
        "description": "Interface endpoint for RDS API calls",
        "order": 132,
        "group": "VPC Endpoints",
        "cost_impact": "+$42/month"
      },
      "enable_ssm_endpoints": {
        "type": "boolean",
        "title": "Enable SSM Endpoints",
        "description": "Interface Endpoints for secure management",
        "default": true,
        "help_text": "Required for secure instance access without SSH/IGW.",
        "group": "Security & Connectivity",
        "isEssential": true,
        "order": 171
      },
      "ssh_access_ip": {
        "type": "string",
        "title": "Admin Access IP (SSH/RDP)",
        "description": "IP address or CIDR block (required for advanced mode)",
        "placeholder": "e.g. 203.0.113.25/32",
        "group": "Security & Connectivity",
        "visibleIf": {
          "ssh_mode": "enabled"
        },
        "isEssential": true,
        "order": 161
      },
      "db_header": {
        "type": "separator",
        "title": "Database Configuration",
        "group": "Database Settings",
        "isEssential": true,
        "order": 80
      },
      "dbName": {
        "type": "string",
        "title": "Database Name",
        "description": "Primary database name",
        "default": "mydb",
        "group": "Database Settings",
        "isEssential": true,
        "order": 81
      },
      "dbUsername": {
        "type": "string",
        "title": "Master Username",
        "description": "Database administrator username",
        "default": "postgres",
        "group": "Database Settings",
        "isEssential": true,
        "order": 82
      },
      "engineVersion": {
        "type": "string",
        "title": "Engine Version",
        "description": "Version of postgres",
        "default": "15",
        "group": "Database Settings",
        "order": 83
      },
      "instanceClass": {
        "type": "string",
        "title": "Instance Class",
        "description": "Compute and memory capacity",
        "default": "db.t3.micro",
        "enum": [
          "db.t3.micro",
          "db.t3.small",
          "db.t3.medium",
          "db.t3.large",
          "db.m5.large"
        ],
        "group": "Database Settings",
        "isEssential": true,
        "order": 84
      },
      "allocatedStorage": {
        "type": "number",
        "title": "Allocated Storage (GB)",
        "description": "Initial storage capacity",
        "default": 20,
        "group": "Database Settings",
        "order": 85
      },
      "maxAllocatedStorage": {
        "type": "number",
        "title": "Max Storage (GB)",
        "description": "Auto-scaling storage limit",
        "default": 100,
        "group": "Database Settings",
        "order": 86
      },
      "backupRetentionDays": {
        "type": "number",
        "title": "Backup Retention (Days)",
        "description": "Number of days to keep backups",
        "default": 3,
        "group": "Database Settings",
        "order": 87
      },
      "security_header": {
        "type": "separator",
        "title": "Security Group Configuration",
        "group": "Security & Connectivity",
        "isEssential": true,
        "order": 155
      },
      "ssh_mode": {
        "type": "select",
        "title": "Access Mode",
        "description": "Choose between secure SSM access or emergency SSH/RDP",
        "default": "ssm-only",
        "options": [
          {
            "label": "Standard (SSM Only)",
            "value": "ssm-only"
          },
          {
            "label": "Advanced (Enable SSH/RDP)",
            "value": "enabled"
          }
        ],
        "group": "Security & Connectivity",
        "isEssential": false,
        "order": 160,
        "help_text": "Standard Security Policy\nSSH and RDP ports remain closed. Secure management via AWS Systems Manager (SSM) is enabled by default."
      },
      "endpoint_header": {
        "type": "separator",
        "title": "Endpoint Configuration",
        "group": "Security & Connectivity",
        "isEssential": true,
        "order": 170
      },
      "enable_s3_endpoint": {
        "type": "boolean",
        "title": "Enable S3 Endpoint",
        "description": "Private gateway access to S3",
        "default": true,
        "group": "Security & Connectivity",
        "isEssential": true,
        "order": 172
      },
      "enable_dynamodb_endpoint": {
        "type": "boolean",
        "title": "Enable DynamoDB Endpoint",
        "description": "Private gateway access to DynamoDB",
        "default": true,
        "group": "Security & Connectivity",
        "isEssential": true,
        "order": 173
      },
      "port_header": {
        "type": "separator",
        "title": "Custom Port Overrides",
        "group": "Security & Connectivity",
        "isEssential": true,
        "order": 180
      },
      "web_port": {
        "type": "number",
        "title": "Web Traffic Port",
        "description": "Standard port for web traffic (HTTP)",
        "default": 80,
        "group": "Security & Connectivity",
        "isEssential": true,
        "order": 181
      },
      "app_port": {
        "type": "number",
        "title": "Application Port",
        "description": "Port for internal application services",
        "default": 8080,
        "group": "Security & Connectivity",
        "isEssential": true,
        "order": 182
      },
      "db_port": {
        "type": "number",
        "title": "Database Port",
        "description": "Port for database connections",
        "default": 5432,
        "group": "Security & Connectivity",
        "isEssential": true,
        "order": 183
      }
    },
    "smart_defaults": {}
  },
  "resources": [
    {
      "id": "aws-rds-postgres:{namer_resource}",
      "type": "aws:rds:SubnetGroup",
      "name": "{namer_resource}",
      "description": "aws:rds:SubnetGroup resource",
      "category": "Other",
      "smart_defaults": {
        "subnet_ids": "{config_subnet_ids}",
        "description": "Subnet group for {db_identifier}",
        "tags": {
          "Name": "{sng_name}"
        }
      },
      "optional": false,
      "dependencies": [],
      "dependents": []
    },
    {
      "id": "aws-rds-postgres:{namer_rds}",
      "type": "aws:rds:Instance",
      "name": "{namer_rds}",
      "description": "aws:rds:Instance resource",
      "category": "Other",
      "smart_defaults": {
        "instance_class": "{config_db_instance_class}",
        "allocated_storage": "{config_allocated_storage}",
        "engine": "postgres",
        "engine_version": "{config_engine_version}",
        "identifier": "{namer_rds}",
        "db_name": "{config_db_name}",
        "username": "{config_db_username}",
        "password": "{db_password}",
        "db_subnet_group_name": "{config_name}",
        "vpc_security_group_ids": [
          "{sg_id}"
        ],
        "publicly_accessible": "{config_publicly_accessible}",
        "multi_az": "{computed}",
        "storage_type": "gp3",
        "storage_encrypted": "{config_storage_encrypted}",
        "backup_retention_period": "{config_backup_retention_days}",
        "skip_final_snapshot": "{config_skip_final_snapshot}",
        "performance_insights_enabled": true,
        "performance_insights_retention_period": 7,
        "copy_tags_to_snapshot": true,
        "deletion_protection": true,
        "tags": {
          "Name": "{db_identifier}"
        }
      },
      "optional": false,
      "dependencies": [],
      "dependents": []
    },
