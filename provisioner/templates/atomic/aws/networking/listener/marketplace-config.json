{
  "action_name": "listener-atomic",
  "version": "latest",
  "description": "Create a standalone AWS Load Balancer Listener for advanced load balancing configurations. This atomic template deploys only the listener component, perfect for expert users building custom load balancer architectures or managing listeners independently. Requires existing Load Balancer and Target Group ARNs.",
  "resources": [
    {
      "type": "aws:lb:Listener",
      "name": "listener",
      "description": "Load Balancer Listener for accepting and routing traffic",
      "config": {
        "loadBalancerArn": "{load_balancer_arn}",
        "port": "{port}",
        "protocol": "{protocol}",
        "defaultActions": [
          {
            "type": "forward",
            "targetGroupArn": "{target_group_arn}"
          }
        ],
        "certificateArn": "{certificate_arn}",
        "sslPolicy": "{ssl_policy}",
        "tags": {
          "Name": "{project_name}-listener",
          "Project": "{project_name}",
          "Environment": "{environment}",
          "ManagedBy": "Archie"
        }
      }
    }
  ],
  "configuration": {
    "smart_defaults": {
      "load_balancer_arn": "",
      "port": 80,
      "protocol": "HTTP",
      "target_group_arn": "",
      "certificate_arn": "",
      "ssl_policy": "ELBSecurityPolicy-2016-08",
      "project_name": "my-project",
      "environment": "dev"
    }
  },
  "parameters": {
    "loadBalancerArn": {
      "type": "string",
      "default": "",
      "description": "ARN of the existing Load Balancer",
      "required": true,
      "placeholder": "arn:aws:elasticloadbalancing:us-east-1:123456789012:loadbalancer/app/my-lb/1234567890123456",
      "help_text": "ARN of the Load Balancer to attach this listener to"
    },
    "port": {
      "type": "number",
      "default": 80,
      "description": "Port on which the listener listens",
      "required": true,
      "placeholder": "80",
      "help_text": "Port number (1-65535)"
    },
    "protocol": {
      "type": "string",
      "default": "HTTP",
      "description": "Protocol for connections from clients",
      "required": true,
      "allowed_values": ["HTTP", "HTTPS", "TCP", "UDP", "TCP_UDP", "TLS"],
      "help_text": "Choose the protocol for client connections"
    },
    "targetGroupArn": {
      "type": "string",
      "default": "",
      "description": "ARN of the target group to forward traffic to",
      "required": true,
      "placeholder": "arn:aws:elasticloadbalancing:us-east-1:123456789012:targetgroup/my-tg/1234567890123456",
      "help_text": "ARN of the Target Group for traffic forwarding"
    },
    "certificateArn": {
      "type": "string",
      "default": "",
      "description": "ARN of the SSL certificate (required for HTTPS/TLS)",
      "required": false,
      "placeholder": "arn:aws:acm:us-east-1:123456789012:certificate/12345678-1234-1234-1234-123456789012",
      "help_text": "Required when protocol is HTTPS or TLS"
    },
    "sslPolicy": {
      "type": "string",
      "default": "ELBSecurityPolicy-2016-08",
      "description": "SSL policy for HTTPS/TLS listeners",
      "required": false,
      "placeholder": "ELBSecurityPolicy-2016-08",
      "help_text": "Security policy for SSL/TLS negotiations"
    },
    "projectName": {
      "type": "string",
      "default": "my-project",
      "description": "Project name for resource naming",
      "required": true,
      "placeholder": "my-project"
    },
    "environment": {
      "type": "string",
      "default": "dev",
      "description": "Environment name",
      "required": false,
      "placeholder": "dev"
    }
  }
}